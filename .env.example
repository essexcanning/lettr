# Lettr — environment variables (copy to .env, fill in real values)

# MongoDB Atlas (Hackathon Sandbox)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lettr

# LiveKit Cloud (voice infra)
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Fireworks AI (LLM inference, OpenAI-compatible)
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Voyage AI (embeddings, MongoDB-native)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# ElevenLabs (TTS in voice pipeline + outbound voicemail)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Deepgram (STT — free tier ok for hackathon)
DEEPGRAM_API_KEY=

# LangSmith (tracing — judges will see it)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=lettr-hackathon
